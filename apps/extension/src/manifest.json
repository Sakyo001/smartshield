{
  "manifest_version": 3,
  "name": "SmartShield",
  "version": "1.0.0",
  "description": "AI-powered phishing protection for your browser",
  
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "identity",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://smartshield-whois-api.onrender.com/*",
    "https://jlgktijajxapqclgjyjx.supabase.co/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartShield - Check this page"
  }
}