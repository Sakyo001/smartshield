{
  "manifest_version": 4,
  "name": "SmartShield",
  "version": "1.0.1",
  "description": "AI-powered phishing protection for your browser",
  
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://railway-whois-production.up.railway.app/*",
    "https://jlgktijajxapqclgjyjx.supabase.co/*",
    "https://web-production-568aa.up.railway.app/*",
    "https://smartshield.it.com/*",
    "https://www.smartshield.it.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartShield - Check this page"
  },

  "web_accessible_resources": [
    {
      "resources": ["images/light-logo-extension.png"],
      "matches": ["<all_urls>"]
    }
  ]
}