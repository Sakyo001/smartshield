# Exclude everything except packages/ml
*
!packages/ml

# Then exclude specific files within packages/ml
packages/ml/__pycache__
packages/ml/*.pyc
packages/ml/*.pyo
packages/ml/*.pyd
packages/ml/.Python
packages/ml/*.so
packages/ml/*.egg
packages/ml/*.egg-info/
packages/ml/dist/
packages/ml/build/
packages/ml/.env
packages/ml/.venv
packages/ml/venv/
packages/ml/ENV/
packages/ml/env/
packages/ml/*.log
packages/ml/.DS_Store
packages/ml/.vscode/
packages/ml/.idea/
packages/ml/*.swp
packages/ml/*.swo
packages/ml/*~
packages/ml/.turbo/
packages/ml/test_*.py
packages/ml/*.bat
packages/ml/*.sh
packages/ml/README.md
packages/ml/RAILWAY_DEPLOY.md
packages/ml/database_setup.sql
packages/ml/requirements-complete.txt
packages/ml/requirements-whois.txt
packages/ml/.renderignore
packages/ml/render.yaml

# Node modules (not needed for Python build)
node_modules/
apps/
packages/lib/
packages/utils/
.git/
.turbo/
.venv/
.vercel/
